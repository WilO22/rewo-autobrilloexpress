rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS GLOBALES ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'SUPER_ADMIN';
    }

    function isManagerOfBranch(branchId) {
      return isAuthenticated() && 
             (getUserData().role == 'MANAGER' && getUserData().branchId == branchId) || 
             isSuperAdmin();
    }

    function belongsToBranch(branchId) {
      return isAuthenticated() && (getUserData().branchId == branchId || isSuperAdmin());
    }

    // --- REGLAS POR COLECCIÓN ---

    // Perfiles de Usuario: Solo el propio usuario lee, solo SuperAdmin escribe roles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'branchId'])) || isSuperAdmin();
      allow create: if isSuperAdmin();
    }

    // Sucursales: Lectura pública (para selección inicial), escritura solo SuperAdmin
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Órdenes: Aislamiento estricto por sucursal
    match /orders/{orderId} {
      // Lectura por cliente (uid) o por equipo de la sucursal
      allow get: if isAuthenticated() && (belongsToBranch(resource.data.branchId) || request.auth.uid == resource.data.customerId);
      allow list: if belongsToBranch(resource.data.branchId);
      
      allow create: if belongsToBranch(request.resource.data.branchId) &&
                    request.resource.data.keys().hasAll(['vehiclePlate', 'status', 'branchId', 'createdAt']);
      
      allow update: if belongsToBranch(resource.data.branchId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['branchId', 'createdAt']);
    }

    // Inventario: Solo Managers de la sucursal o SuperAdmin
    match /inventory/{itemId} {
      allow read: if belongsToBranch(resource.data.branchId);
      allow create: if isManagerOfBranch(request.resource.data.branchId);
      allow update: if isManagerOfBranch(request.resource.data.branchId);
      allow delete: if isManagerOfBranch(resource.data.branchId);
    }

    // Clientes: Aislamiento de PII (Solo el cliente o staff de sede accede)
    match /customers/{customerId} {
      // Lectura individual por el cliente o cualquier staff con sede activa
      allow get: if isAuthenticated() && (request.auth.uid == customerId || getUserData().branchId != null || isSuperAdmin());
      // Listado solo para personal interno con sede o administradores globales
      allow list: if isAuthenticated() && (getUserData().branchId != null || isSuperAdmin());

      allow create: if true; // Registro abierto (Landing)
      
      // Blindaje de Puntos: Solo staff, solo incrementos razonables (max 500)
      allow update: if isSuperAdmin() || 
                    (isAuthenticated() && 
                     (getUserData().branchId != null || isSuperAdmin()) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'updatedAt']) &&
                     (request.resource.data.points - resource.data.points) <= 500); // Evita inflación masiva
      
      allow delete: if isSuperAdmin();
    }

    // Marketing: Cupones Protegidos (Solo el usuario puede marcar su propio uso)
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || 
                    (isAuthenticated() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy']) &&
                     request.resource.data.usedBy.size() == (resource.data.usedBy.size() + 1) &&
                     request.auth.uid in request.resource.data.usedBy);
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Servicios: Catálogo de paquetes de lavado (Lectura para personal y clientes)
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Agenda: Control de capacidad por sucursal (Ahora permite Operadores de la sede)
    match /branch_slots/{slotId} {
      allow read: if isAuthenticated();
      // Permitir a cualquier operario de la sede escribir en el slot para reservar capacidad
      allow write: if belongsToBranch(slotId.split('_')[0]);
    }



    // Transacciones de Lealtad: Historial de puntos
    match /loyalty_transactions/{txId} {
      allow read: if belongsToBranch(resource.data.branchId);
      allow create: if belongsToBranch(request.resource.data.branchId);
    }

    // Kardex: Auditoría de movimientos de inventario
    match /inventory_movements/{mvId} {
      allow read: if belongsToBranch(resource.data.branchId);
      allow create: if belongsToBranch(request.resource.data.branchId);
      allow update, delete: if false; // Auditoría inmutable
    }
  }
}
